<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    name="comics" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802"
    leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
    uuid="53ba21de-2c76-406e-9cab-3edd8f823b6c">

    <style name="Title" fontName="SansSerif" fontSize="20" isBold="true" forecolor="#1E293B"/>
    <style name="Header" mode="Opaque" backcolor="#334155" forecolor="#FFFFFF" fontName="SansSerif" fontSize="10" isBold="true"/>
    <style name="Detail" fontName="SansSerif" fontSize="10" forecolor="#0F172A"/>

    <field name="idComic" class="java.lang.Integer"/>
    <field name="titulo" class="java.lang.String"/>
    <field name="autor" class="java.lang.String"/>
    <field name="categoria" class="java.lang.String"/>
    <field name="estado" class="java.lang.String"/>

    <title>
        <band height="60">
            <staticText>
                <reportElement x="0" y="10" width="802" height="30" style="Title"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"/>
                <text><![CDATA[Reporte de Comics]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="48" width="802" height="1" forecolor="#94A3B8"/>
            </line>
        </band>
    </title>

    <columnHeader>
        <band height="24">
            <staticText>
                <reportElement x="0" y="0" width="60" height="22" style="Header"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="60" y="0" width="300" height="22" style="Header"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[Titulo]]></text>
            </staticText>
            <staticText>
                <reportElement x="360" y="0" width="180" height="22" style="Header"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[Autor]]></text>
            </staticText>
            <staticText>
                <reportElement x="540" y="0" width="170" height="22" style="Header"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[Categoria]]></text>
            </staticText>
            <staticText>
                <reportElement x="710" y="0" width="92" height="22" style="Header"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[Estado]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="22">
            <textField isBlankWhenNull="true">
                <reportElement x="0" y="2" width="60" height="18" style="Detail"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{idComic}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="60" y="2" width="300" height="18" style="Detail"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{titulo}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="360" y="2" width="180" height="18" style="Detail"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{autor}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="540" y="2" width="170" height="18" style="Detail"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{categoria}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="710" y="2" width="92" height="18" style="Detail"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{estado}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <pageFooter>
        <band height="24">
            <line>
                <reportElement x="0" y="0" width="802" height="1" forecolor="#CBD5E1"/>
            </line>
            <textField>
                <reportElement x="702" y="4" width="100" height="16"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA["Pagina " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

</jasperReport>
