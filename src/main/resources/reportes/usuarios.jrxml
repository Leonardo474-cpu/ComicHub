<!-- Created with Jaspersoft Studio version 7.0.3.final using JasperReports Library version 7.0.3 -->
<jasperReport name="usuarios" language="java" pageWidth="595" pageHeight="842"
	columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
	uuid="fa1284f3-3268-478e-aeea-a804e082dd77">

	<!-- ESTILOS -->
	<style name="Titulo" fontSize="26" bold="true" forecolor="#1e293b"/>
	<style name="Encabezado" mode="Opaque" backcolor="#334155"
		forecolor="#ffffff" bold="true" hTextAlign="Center"/>
	<style name="Detalle" forecolor="#0f172a"/>

	<query language="sql"><![CDATA[]]></query>

	<field name="id" class="java.lang.Integer"/>
	<field name="nombreCompleto" class="java.lang.String"/>
	<field name="correo" class="java.lang.String"/>
	<field name="nombreRol" class="java.lang.String"/>
	<field name="activo" class="java.lang.Boolean"/>

	<background splitType="Stretch"/>

	<!-- TITULO -->
	<title height="80">
		<element kind="staticText" style="Titulo" x="0" y="10" width="555" height="40">
			<text><![CDATA[Reporte de Usuarios]]></text>
		</element>

		<element kind="line" x="0" y="60" width="555" height="1" forecolor="#94a3b8"/>
	</title>

	<!-- ENCABEZADOS -->
	<columnHeader height="35">
		<element kind="staticText" style="Encabezado" x="0" y="0" width="60" height="30">
			<text><![CDATA[ID]]></text>
		</element>

		<element kind="staticText" style="Encabezado" x="60" y="0" width="170" height="30">
			<text><![CDATA[Nombre]]></text>
		</element>

		<element kind="staticText" style="Encabezado" x="230" y="0" width="170" height="30">
			<text><![CDATA[Correo]]></text>
		</element>

		<element kind="staticText" style="Encabezado" x="400" y="0" width="80" height="30">
			<text><![CDATA[Rol]]></text>
		</element>

		<element kind="staticText" style="Encabezado" x="480" y="0" width="75" height="30">
			<text><![CDATA[Estado]]></text>
		</element>
	</columnHeader>

	<!-- DETALLE -->
	<detail>
		<band height="30">

			<element kind="textField" style="Detalle" x="0" y="5" width="60" height="20">
				<expression><![CDATA[$F{id}]]></expression>
			</element>

			<element kind="textField" style="Detalle" x="60" y="5" width="170" height="20">
				<expression><![CDATA[$F{nombreCompleto}]]></expression>
			</element>

			<element kind="textField" style="Detalle" x="230" y="5" width="170" height="20">
				<expression><![CDATA[$F{correo}]]></expression>
			</element>

			<element kind="textField" style="Detalle" x="400" y="5" width="80" height="20">
				<expression><![CDATA[$F{nombreRol}]]></expression>
			</element>

			<!-- Estado con color dinámico -->
			<element kind="textField" x="480" y="5" width="75" height="20">
				<expression><![CDATA[$F{activo} ? "Activo" : "Inactivo"]]></expression>
				<property name="forecolor">
					<![CDATA[$F{activo} ? "#16a34a" : "#dc2626"]]>
				</property>
			</element>

		</band>
	</detail>

	<!-- FOOTER -->
	<pageFooter height="25">
		<element kind="line" x="0" y="0" width="555" height="1" forecolor="#cbd5f5"/>

		<element kind="textField" x="450" y="5" width="100" height="20" hTextAlign="Right">
			<expression><![CDATA["Página " + $V{PAGE_NUMBER}]]></expression>
		</element>
	</pageFooter>

</jasperReport>